<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Xadras" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color (Background da ActionBar) -->
        <item name="colorPrimary">@color/brown_primary</item>
        <item name="colorPrimaryVariant">@color/brown_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Cor do Título e Ícone de Voltar -->
        <item name="titleTextColor">@color/white</item>
        <item name="drawerArrowStyle">@style/DrawerArrowStyle</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/board_dark</item>
        <item name="colorSecondaryVariant">@color/brown_light</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Estilo para a seta de voltar -->
    <style name="DrawerArrowStyle" parent="@style/Widget.AppCompat.DrawerArrowToggle">
        <item name="spinBars">true</item>
        <item name="color">@color/white</item>
    </style>
</resources>