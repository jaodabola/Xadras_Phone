<?xml version="1.0" encoding="utf-8"?>
<!-- Simple chess board icon for loading screen (4x4 pattern) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F0D9B5" />
            <corners android:radius="8dp" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>
    <!-- Chess pattern overlay using inset rectangles -->
    <!-- Row 1: dark squares at columns 1, 3 -->
    <item android:top="0dp" android:left="0dp" android:right="36dp" android:bottom="36dp">
        <shape android:shape="rectangle">
            <solid android:color="#B58863" />
        </shape>
    </item>
    <item android:top="0dp" android:left="24dp" android:right="12dp" android:bottom="36dp">
        <shape android:shape="rectangle">
            <solid android:color="#B58863" />
        </shape>
    </item>
    <!-- Row 2: dark squares at columns 0, 2 -->
    <item android:top="12dp" android:left="12dp" android:right="24dp" android:bottom="24dp">
        <shape android:shape="rectangle">
            <solid android:color="#B58863" />
        </shape>
    </item>
    <item android:top="12dp" android:left="36dp" android:right="0dp" android:bottom="24dp">
        <shape android:shape="rectangle">
            <solid android:color="#B58863" />
        </shape>
    </item>
    <!-- Row 3 -->
    <item android:top="24dp" android:left="0dp" android:right="36dp" android:bottom="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#B58863" />
        </shape>
    </item>
    <item android:top="24dp" android:left="24dp" android:right="12dp" android:bottom="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#B58863" />
        </shape>
    </item>
    <!-- Row 4 -->
    <item android:top="36dp" android:left="12dp" android:right="24dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#B58863" />
        </shape>
    </item>
    <item android:top="36dp" android:left="36dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#B58863" />
        </shape>
    </item>
</layer-list>
