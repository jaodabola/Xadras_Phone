<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Camera preview fills screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- A real AR Overlay View -->
    <com.xadras.app.ui.camera.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════════════════════════════════════════════════
         LOADING OVERLAY — shown while YOLO model loads
         ═══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F0181210"
        android:clickable="true"
        android:focusable="true"
        android:elevation="10dp"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Chess board icon -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_loading_board"
                android:alpha="0.9"
                android:layout_marginBottom="24dp"
                android:contentDescription="Tabuleiro" />

            <!-- Loading title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A preparar o tabuleiro..."
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Loading subtitle -->
            <TextView
                android:id="@+id/tvLoadingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A carregar o modelo de deteção"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="24dp" />

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/progressLoading"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:indeterminateTint="@color/brown_light" />
        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════
         TOP STATUS BAR
         ═══════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Connected indicator dot -->
                <View
                    android:id="@+id/indicatorConnected"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_green"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Aponte a câmara para o tabuleiro"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#88FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Tracker status (move number / turn / FEN state) -->
            <TextView
                android:id="@+id/tvTrackerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#AAFFC107"
                android:textSize="11sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════════════════════
         (The DEBUG VIEW was removed to eliminate Top-Down bitmap lag)
         ═══════════════════════════════════════════════════════ -->

    <!-- ═══════════════════════════════════════════════════════
         BOTTOM CONTROLS
         ═══════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#EE1A1008"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvFenLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FEN detetado"
                android:textColor="#88FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvFen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aguardando deteção..."
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="12dp" />

            <!-- Código de sessão do browser -->
            <TextView
                android:id="@+id/tvSessionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código de sessão do browser:"
                android:textColor="#88FFFFFF"
                android:textSize="11sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSessionCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ex: X7K3P2"
                android:inputType="textCapCharacters"
                android:maxLength="6"
                android:textColor="@color/white"
                android:textColorHint="#55FFFFFF"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.3"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:padding="10dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleBroadcast"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="▶ Transmitir"
                    android:backgroundTint="@color/brown_primary"
                    android:textColor="@color/white"
                    android:padding="14dp" />

                <!-- Reset button (new game) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetTracker"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↻"
                    android:textSize="18sp"
                    android:textColor="@color/white"
                    app:strokeColor="#44FFFFFF"
                    android:layout_marginStart="8dp"
                    android:minWidth="48dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>