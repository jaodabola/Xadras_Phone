<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Camera preview fills screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top status bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <!-- Connected indicator dot -->
            <View
                android:id="@+id/indicatorConnected"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_green"
                android:visibility="gone"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Aponte a câmara para o tabuleiro"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#88FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom controls -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#EE1A1008"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvFenLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FEN detetado"
                android:textColor="#88FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvFen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aguardando deteção..."
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="12dp" />

            <!-- Código de sessão do browser -->
            <TextView
                android:id="@+id/tvSessionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código de sessão do browser:"
                android:textColor="#88FFFFFF"
                android:textSize="11sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSessionCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ex: X7K3P2"
                android:inputType="textCapCharacters"
                android:maxLength="6"
                android:textColor="@color/white"
                android:textColorHint="#55FFFFFF"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.3"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:padding="10dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleBroadcast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▶ Transmitir"
                android:backgroundTint="@color/brown_primary"
                android:textColor="@color/white"
                android:padding="14dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>